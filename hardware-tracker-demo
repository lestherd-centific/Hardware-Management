// Renames a bucket everywhere it's used as a key: the buckets list, its
// locations, its Hardware/Accessories tab state, minimized/featured
// tracking, and every device/accessory currently assigned to it.
function renameBucket(oldName, newName){
  const idx = state.buckets.indexOf(oldName);
  if (idx === -1) return;
  state.buckets[idx] = newName;
  state.locations[newName] = state.locations[oldName] || [];
  delete state.locations[oldName];
  state.accTab[newName] = state.accTab[oldName] || "hardware";
  delete state.accTab[oldName];
  const minIdx = state.minimized.indexOf(oldName);
  if (minIdx >= 0) state.minimized[minIdx] = newName;
  if (state.featured === oldName) state.featured = newName;
  state.devices.forEach(d => { if (d.bucket === oldName) d.bucket = newName; });
  state.accessories.forEach(a => { if (a.bucket === oldName) a.bucket = newName; });
  logActivity({ ts: new Date().toLocaleString(), type: "rename", tag: newName, from: oldName, to: newName });
}

