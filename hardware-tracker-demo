<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Hardware Tracker — Demo</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --c-violet:#6d28d9; --c-violet-soft:#f1eafe; --c-pink:#ec4899; --c-pink-soft:#fdeef7;
    --bg:#f7f6fb; --panel:#ffffff; --ink:#1c1b29; --sub:#68657a;
    --border:#e7e3f0; --hover-bg:#faf9fd; --note-bg:#fbf8ff; --footer-muted:#b4afc4;
    --st-instock:#2563eb; --st-instock-bg:#e7edfd;
    --st-inuse:#16a34a; --st-inuse-bg:#e6f7ec;
    --st-broken:#dc2626; --st-broken-bg:#fdeaea;
    --drop-green:#16a34a; --drop-green-bg:rgba(22,163,74,.06); --drop-green-bg-active:rgba(22,163,74,.16);
  }
  html[data-theme="dark"]{
    --c-violet:#a684f5; --c-violet-soft:#2a2140; --c-pink:#f472b6; --c-pink-soft:#38233a;
    --bg:#15141d; --panel:#1e1c29; --ink:#f1eef8; --sub:#9c98b0;
    --border:#33314a; --hover-bg:#262433; --note-bg:#211f30; --footer-muted:#57546c;
    --st-instock:#7aa8fb; --st-instock-bg:#1c2745;
    --st-inuse:#5fdb95; --st-inuse-bg:#183226;
    --st-broken:#f9847c; --st-broken-bg:#3c2020;
    --drop-green:#5fdb95; --drop-green-bg:rgba(95,219,149,.1); --drop-green-bg-active:rgba(95,219,149,.22);
  }
  *{box-sizing:border-box;}
  body{margin:0;font-family:'DM Sans',-apple-system,Segoe UI,Roboto,sans-serif;background:var(--bg);color:var(--ink);transition:background-color .15s,color .15s;}
  header{background:var(--panel);border-bottom:1px solid var(--border);padding:18px 24px;display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:14px;}
  .eyebrow{font-size:11px;font-weight:700;letter-spacing:.09em;color:var(--c-violet);text-transform:uppercase;margin-bottom:4px;}
  header h1{font-size:20px;margin:0;font-weight:500;color:var(--ink);}
  .toolbar{display:flex;gap:8px;flex-wrap:wrap;align-items:center;}
  input[type=text]{padding:8px 10px;border:1px solid var(--border);border-radius:7px;font-size:13px;min-width:180px;font-family:inherit;background:var(--panel);color:var(--ink);}
  select{font-family:inherit;background:var(--panel);color:var(--ink);}
  button{padding:8px 12px;border:1px solid var(--border);border-radius:7px;background:var(--panel);font-size:13px;cursor:pointer;color:var(--ink);font-family:inherit;}
  button.primary{background:var(--c-violet);color:#fff;border-color:var(--c-violet);}
  button:hover{filter:brightness(0.97);}
  main{padding:20px 24px 8px;}

  .quickmove{background:var(--panel);border:1px solid var(--border);border-radius:10px;padding:14px 16px;margin-bottom:16px;position:relative;}
  .quickmove h3{margin:0 0 10px 0;font-size:13px;font-weight:600;color:var(--sub);text-transform:uppercase;letter-spacing:.03em;}
  .qm-hint{font-size:11.5px;color:var(--sub);margin:-6px 0 10px;}
  .quickmove .row{display:flex;gap:8px;flex-wrap:wrap;align-items:center;}
  .qm-input-wrap{position:relative;flex:1;min-width:220px;}
  .qm-tag-box{display:flex;flex-wrap:wrap;gap:6px;align-items:center;border:1px solid var(--border);border-radius:8px;padding:6px 8px;background:var(--panel);}
  .qm-tag-box:focus-within{border-color:var(--c-violet);}
  .qm-tags{display:contents;}
  .qm-tag{display:inline-flex;align-items:center;gap:5px;background:var(--c-violet-soft);color:var(--c-violet);border-radius:999px;padding:3px 6px 3px 10px;font-size:12px;font-weight:600;white-space:nowrap;}
  .qm-tag button{border:none;background:none;color:inherit;cursor:pointer;font-size:13px;line-height:1;padding:0 2px;font-family:inherit;}
  .qm-tag button:hover{color:var(--st-broken);}
  .qm-tag-box input[type=text]{flex:1;min-width:140px;border:none;background:transparent;padding:4px 2px;}
  .qm-tag-box input[type=text]:focus{outline:none;}
  .qm-suggestions{position:absolute;top:calc(100% + 6px);left:0;right:0;background:var(--panel);border:1px solid var(--border);border-radius:8px;box-shadow:0 8px 22px rgba(0,0,0,.25);max-height:220px;overflow-y:auto;z-index:6;display:none;}
  .qm-suggestions.open{display:block;}
  .qm-suggestions .item{padding:8px 12px;font-size:12.5px;cursor:pointer;border-bottom:1px solid var(--border);}
  .qm-suggestions .item:last-child{border-bottom:none;}
  .qm-suggestions .item:hover{background:var(--c-violet-soft);}
  .qm-suggestions .item b{color:var(--ink);}
  .qm-suggestions .item .where{color:var(--sub);}
  .qm-feedback{font-size:12.5px;margin-top:8px;}
  .qm-feedback.ok{color:var(--st-inuse);}
  .qm-feedback.err{color:var(--st-broken);}

  .model-summary{background:var(--panel);border:1px solid var(--border);border-radius:10px;padding:14px 16px;margin-bottom:16px;}
  .model-summary h3{margin:0 0 10px 0;font-size:13px;font-weight:600;color:var(--sub);text-transform:uppercase;letter-spacing:.03em;}
  .model-table{width:100%;border-collapse:collapse;font-size:13px;}
  .model-table th{text-align:left;font-size:11px;font-weight:600;color:var(--sub);text-transform:uppercase;letter-spacing:.03em;padding:6px 10px;border-bottom:1px solid var(--border);}
  .model-table th.num,.model-table td.num{text-align:right;}
  .model-table td{padding:7px 10px;border-bottom:1px solid var(--border);}
  .model-table tbody tr:hover{background:var(--hover-bg);}
  .model-table tbody tr:last-child td{border-bottom:none;}
  .model-table tfoot td{padding:8px 10px;font-weight:700;border-top:2px solid var(--border);border-bottom:none;}
  .model-table .status-num.instock{color:var(--st-instock);}
  .model-table .status-num.inuse{color:var(--st-inuse);}
  .model-table .status-num.broken{color:var(--st-broken);}
  .model-table-wrap{max-height:380px;overflow-y:auto;}
  .model-table thead th{position:sticky;top:0;background:var(--panel);z-index:2;}
  .model-table tfoot td{position:sticky;bottom:0;background:var(--panel);}
  .model-row-click{cursor:pointer;}

  .layout{display:flex;gap:20px;align-items:flex-start;}

  .panel-main{flex:1 1 62%;background:var(--panel);border:1px solid var(--border);border-radius:12px;overflow:hidden;min-width:0;}
  .panel-head{padding:14px 16px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;background:linear-gradient(90deg,var(--c-violet-soft),transparent);}
  .panel-head h2{margin:0;font-size:15px;font-weight:600;}
  .panel-head .tag{font-size:11px;color:var(--c-violet);font-weight:600;text-transform:uppercase;letter-spacing:.04em;}
  .head-actions{display:flex;align-items:center;gap:6px;flex-wrap:wrap;}
  .pin-btn,.icon-btn{font-size:11px;padding:5px 9px;border-radius:6px;border:1px solid var(--border);background:var(--panel);cursor:pointer;white-space:nowrap;font-family:inherit;color:var(--ink);}
  .pin-btn:hover,.icon-btn:hover{filter:brightness(0.97);}
  .pin-btn.unpin{color:var(--c-violet);border-color:var(--c-violet);background:var(--c-violet-soft);}
  .icon-btn.archive{color:var(--st-broken);border-color:var(--st-broken);}
  .count-pill{background:var(--c-violet);color:#fff;font-size:12px;padding:2px 10px;border-radius:999px;font-weight:600;}

  .panel-tabs{display:flex;gap:6px;align-items:center;padding:8px 16px 0;border-bottom:1px solid var(--border);}
  .tab-btn{border:none;background:none;padding:6px 10px;border-radius:8px 8px 0 0;font-size:12px;font-weight:600;color:var(--sub);cursor:pointer;font-family:inherit;display:inline-flex;align-items:center;gap:5px;}
  .tab-btn:hover{color:var(--ink);}
  .tab-btn.active{color:var(--c-violet);background:var(--c-violet-soft);}
  .tab-count{font-size:10px;font-weight:700;opacity:.8;background:rgba(0,0,0,.06);border-radius:999px;padding:1px 6px;}
  .tab-btn.active .tab-count{background:rgba(255,255,255,.5);}
  .tab-add-btn{margin-left:auto;border:1px solid var(--c-violet);color:var(--c-violet);background:var(--c-violet-soft);font-size:11px;font-weight:600;padding:5px 9px;border-radius:6px;cursor:pointer;font-family:inherit;white-space:nowrap;}
  .tab-add-btn:hover{filter:brightness(0.97);}

  .archived-panel{background:var(--panel);border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:14px;}
  .archived-panel-head{padding:10px 16px;font-size:11px;font-weight:700;color:var(--sub);text-transform:uppercase;letter-spacing:.04em;border-bottom:1px solid var(--border);background:var(--hover-bg);display:flex;justify-content:space-between;align-items:center;cursor:pointer;user-select:none;}
  .archived-panel-head:hover{color:var(--ink);}
  .archived-panel.collapsed .archived-item{display:none;}
  .archived-panel.collapsed .archived-panel-head{border-bottom:none;}
  .archived-toggle{font-size:11px;}
  .archived-item{display:flex;justify-content:space-between;align-items:center;padding:9px 16px;border-bottom:1px solid var(--border);font-size:13px;}
  .archived-item-actions{display:flex;gap:6px;align-items:center;}
  .archived-item:last-child{border-bottom:none;}
  .archived-item .meta{color:var(--sub);font-size:11.5px;}
  .restore-btn{font-size:11px;padding:5px 9px;border-radius:6px;border:1px solid var(--c-violet);color:var(--c-violet);background:var(--c-violet-soft);cursor:pointer;font-family:inherit;white-space:nowrap;}
  .restore-btn:hover{filter:brightness(0.97);}

  .drop-target{max-height:0;margin:0 16px;padding:0 12px;border:2px dashed transparent;border-radius:9px;background:var(--drop-green-bg);color:var(--drop-green);font-size:12px;font-weight:600;text-align:center;overflow:hidden;opacity:0;transition:max-height .18s ease,opacity .15s ease,margin .18s ease,padding .18s ease,border-color .15s,background .15s;}
  body.dragging-device .drop-target[data-kind="hardware"]{max-height:60px;margin:10px 16px;padding:9px 12px;border-color:var(--drop-green);opacity:1;}
  body.dragging-accessory .drop-target[data-kind="accessory"]{max-height:60px;margin:10px 16px;padding:9px 12px;border-color:var(--drop-green);opacity:1;}
  .drop-target.dragover{background:var(--drop-green-bg-active);border-color:var(--drop-green);}

  .dd-modal{width:420px;max-height:82vh;overflow-y:auto;}
  .dd-modal-head{display:flex;justify-content:space-between;align-items:flex-start;}
  .dd-modal-head h3{margin:0;}
  .dd-close-x{border:none;background:none;font-size:16px;cursor:pointer;color:var(--sub);line-height:1;padding:2px;}
  .dd-close-x:hover{color:var(--ink);}
  .dd-meta{font-size:13px;color:var(--sub);line-height:1.8;margin:6px 0 16px;padding:10px 12px;background:var(--bg);border-radius:8px;}
  .dd-meta b{color:var(--ink);}
  .dd-status-chip{font-size:11px;padding:2px 8px;border-radius:6px;font-weight:600;}
  .dd-section-label{font-size:11px;font-weight:700;color:var(--sub);text-transform:uppercase;letter-spacing:.03em;margin:0 0 6px;}
  .dd-list{max-height:170px;overflow-y:auto;margin-bottom:14px;border:1px solid var(--border);border-radius:8px;padding:2px 12px;}
  .dd-note-item{font-size:12.5px;color:var(--ink);padding:7px 0;border-bottom:1px dashed var(--border);display:flex;justify-content:space-between;align-items:flex-start;gap:8px;}
  .dd-note-item:last-child{border-bottom:none;}
  .dd-note-item .txt{flex:1;}
  .dd-note-item .date{color:var(--sub);font-size:11px;white-space:nowrap;}
  .dd-note-del{background:none;border:none;color:var(--st-broken);cursor:pointer;font-size:12px;opacity:.6;flex-shrink:0;}
  .dd-note-del:hover{opacity:1;}
  .dd-note-input{width:100%;min-height:60px;padding:8px;border:1px solid var(--border);border-radius:7px;font-size:13px;font-family:inherit;resize:vertical;background:var(--panel);color:var(--ink);}

  .col-labels.full,.row.full{grid-template-columns:20px minmax(60px,1fr) minmax(70px,1.4fr) minmax(70px,1.4fr) 118px;}
  .col-labels.compact,.row.compact{grid-template-columns:18px minmax(50px,1fr) minmax(60px,1.2fr) 100px;}
  .col-labels.full.loc,.row.full.loc{grid-template-columns:20px minmax(50px,0.9fr) minmax(60px,1.1fr) minmax(60px,1.1fr) 106px minmax(90px,0.9fr);}
  .col-labels.compact.loc,.row.compact.loc{grid-template-columns:18px minmax(45px,0.9fr) minmax(55px,1fr) 96px minmax(85px,0.9fr);}
  .col-labels.acc.full,.row.acc.full{grid-template-columns:20px minmax(60px,1fr) minmax(50px,0.8fr) minmax(80px,1.2fr) 100px minmax(80px,0.9fr) 22px;}
  .col-labels.acc.compact,.row.acc.compact{grid-template-columns:18px minmax(55px,1fr) minmax(45px,0.8fr) 92px minmax(75px,0.9fr) 22px;}
  .acc-del-btn{border:none;background:none;color:var(--sub);cursor:pointer;font-size:12px;opacity:.55;padding:0;}
  .acc-del-btn:hover{opacity:1;color:var(--st-broken);}
  .col-labels{display:grid;gap:8px;padding:8px 16px;font-size:11px;font-weight:600;color:var(--sub);text-transform:uppercase;letter-spacing:.03em;border-bottom:1px solid var(--border);}
  .rows-list{max-height:560px;overflow-y:auto;}
  .rows-list.dragover{background:var(--c-violet-soft);}
  .row{display:grid;gap:8px;align-items:center;padding:7px 16px;border-bottom:1px solid var(--border);font-size:12.8px;cursor:grab;}
  .row:hover{background:var(--hover-bg);}
  .row:active{cursor:grabbing;}
  .row .handle{color:var(--sub);opacity:.5;font-size:13px;}
  .row .cell{overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
  .row .cell.serial{font-weight:600;color:var(--ink);}
  .row .cell.dd-open{cursor:pointer;text-decoration:underline;text-decoration-color:transparent;transition:text-decoration-color .1s;}
  .row .cell.dd-open:hover{text-decoration-color:currentColor;}
  .note-badge{font-size:10px;color:var(--c-violet);margin-left:3px;font-weight:600;}
  .row .cell.sub{color:var(--sub);}
  .sortable-col{cursor:pointer;user-select:none;}
  .sortable-col:hover{color:var(--ink);}
  .row select{font-size:12px;padding:4px 6px;border-radius:6px;border:1px solid var(--border);background:var(--panel);color:var(--ink);max-width:100%;}
  .status-select.instock{color:var(--st-instock);background:var(--st-instock-bg);border-color:transparent;}
  .status-select.inuse{color:var(--st-inuse);background:var(--st-inuse-bg);border-color:transparent;}
  .status-select.broken{color:var(--st-broken);background:var(--st-broken-bg);border-color:transparent;}
  .empty-hint{color:var(--sub);font-size:12px;text-align:center;padding:24px 6px;}
  .empty-hint.small{padding:10px 6px;font-size:11.5px;}

  .loc-group{width:100%;}
  .loc-group-head{display:flex;justify-content:space-between;align-items:center;gap:8px;padding:6px 16px;font-size:10.5px;font-weight:700;color:var(--sub);text-transform:uppercase;letter-spacing:.04em;background:var(--hover-bg);border-top:1px solid var(--border);border-bottom:1px solid var(--border);}
  .loc-group:first-child .loc-group-head{border-top:none;}
  .loc-count{font-weight:600;opacity:.75;}
  .loc-del-btn{border:none;background:none;color:var(--sub);cursor:pointer;font-size:10.5px;font-family:inherit;text-transform:none;letter-spacing:normal;opacity:.7;padding:0 2px;white-space:nowrap;}
  .loc-del-btn:hover{opacity:1;color:var(--st-broken);}
  .settings-loc-row{display:flex;justify-content:space-between;align-items:center;padding:6px 10px;border:1px solid var(--border);border-radius:6px;margin-top:6px;font-size:13px;}
  .settings-loc-row .loc-del-btn{font-size:13px;}

  .sidebar{flex:1 1 38%;display:flex;flex-direction:column;gap:14px;min-width:0;}
  .mini-card{background:var(--panel);border:1px solid var(--border);border-radius:12px;overflow:hidden;cursor:grab;}
  .mini-card:active{cursor:grabbing;}
  .mini-card.card-dragover{outline:2px dashed var(--c-pink);outline-offset:-2px;}
  .mini-card .panel-head{background:linear-gradient(90deg,var(--c-pink-soft),transparent);}
  .mini-card .panel-head .tag{color:var(--c-pink);}
  .mini-card .count-pill{background:var(--c-pink);}
  .mini-card .rows-list{max-height:260px;}
  .mini-card.minimized .col-labels,.mini-card.minimized .rows-list,.mini-card.minimized .drop-target{display:none;}
  .card-handle{color:var(--sub);opacity:.55;margin-right:4px;font-size:13px;}
  .minimize-btn{font-size:12px;line-height:1;padding:5px 8px;}

  aside.log{margin-top:20px;background:var(--panel);border:1px solid var(--border);border-radius:12px;padding:14px 16px;}
  aside.log h3{margin:0 0 8px 0;font-size:13px;font-weight:600;color:var(--sub);text-transform:uppercase;letter-spacing:.03em;}
  #logList{max-height:420px;overflow-y:auto;}
  .log-entry{font-size:12.5px;color:var(--sub);padding:6px 0;border-bottom:1px dashed var(--border);}
  .log-entry:last-child{border-bottom:none;}
  .log-entry b{color:var(--ink);}

  .modal-backdrop{display:none;position:fixed;inset:0;background:rgba(28,27,41,.35);align-items:center;justify-content:center;z-index:10;}
  .modal-backdrop.open{display:flex;}
  .modal{background:var(--panel);color:var(--ink);border-radius:12px;padding:20px;width:340px;}
  .modal.modal-wide{width:560px;max-width:90vw;max-height:85vh;overflow-y:auto;}
  .modal h3{margin-top:0;font-weight:600;}
  .modal label{display:block;font-size:12px;color:var(--sub);margin-top:10px;margin-bottom:4px;}
  .modal input,.modal select{width:100%;padding:8px;border:1px solid var(--border);border-radius:7px;font-size:13px;font-family:inherit;background:var(--panel);color:var(--ink);}
  .modal-actions{display:flex;justify-content:flex-end;gap:8px;margin-top:16px;}
  .suggest-wrap{position:relative;}
  .suggest-dropdown{position:absolute;top:calc(100% + 4px);left:0;right:0;background:var(--panel);border:1px solid var(--border);border-radius:8px;box-shadow:0 8px 22px rgba(0,0,0,.25);max-height:170px;overflow-y:auto;z-index:20;display:none;}
  .suggest-dropdown.open{display:block;}
  .suggest-dropdown .item{padding:7px 12px;font-size:12.5px;cursor:pointer;border-bottom:1px solid var(--border);}
  .suggest-dropdown .item:last-child{border-bottom:none;}
  .suggest-dropdown .item:hover{background:var(--c-violet-soft);}
  .md-breakdown-list{max-height:260px;overflow-y:auto;border:1px solid var(--border);border-radius:8px;}
  .md-breakdown-row{display:flex;justify-content:space-between;align-items:center;padding:9px 14px;border-bottom:1px solid var(--border);font-size:13px;}
  .md-breakdown-row:last-child{border-bottom:none;}
  .md-breakdown-row .proj{font-weight:600;}
  .md-breakdown-row .proj .master-tag{font-weight:500;color:var(--sub);font-size:11px;margin-left:6px;}
  .md-breakdown-row .qty{background:var(--c-violet-soft);color:var(--c-violet);border-radius:999px;padding:2px 12px;font-weight:700;font-size:12.5px;}
  .model-tag-chips{display:flex;flex-wrap:wrap;gap:6px;margin-top:8px;}
  .model-tag{display:inline-flex;align-items:center;gap:5px;background:var(--c-violet-soft);color:var(--c-violet);border-radius:999px;padding:3px 6px 3px 10px;font-size:12px;font-weight:600;white-space:nowrap;}
  .model-tag button{border:none;background:none;color:inherit;cursor:pointer;font-size:13px;line-height:1;padding:0 2px;font-family:inherit;}
  .model-tag button:hover{color:var(--st-broken);}

  footer.note{margin:20px 24px 8px;font-size:12.5px;color:var(--sub);line-height:1.5;background:var(--note-bg);border:1px solid var(--border);padding:12px 14px;border-radius:10px;}
  footer.brand{text-align:center;color:var(--footer-muted);font-size:11px;padding:18px 0 28px;}

  @media (max-width: 900px){
    .layout{flex-direction:column;}
    .col-labels{display:none;}
  }
</style>
</head>
<body>

<header>
  <div>
    <div class="eyebrow">Hardware Tracker</div>
    <h1>Master Inventory &amp; Project Allocations</h1>
  </div>
  <div class="toolbar">
    <input type="text" id="search" placeholder="Search asset tag, model, serial, or tag (e.g. Tablet)...">
    <button id="addProjectBtn">+ Project</button>
    <button id="addAssetBtn" class="primary">+ Asset</button>
    <button id="exportBtn">Export JSON</button>
    <button id="importBtn">Import JSON</button>
    <input type="file" id="importFile" accept="application/json" style="display:none">
    <button id="themeToggle" title="Toggle dark mode">🌙 Dark</button>
  </div>
</header>

<main>

  <div class="quickmove">
    <h3>Move by serial number</h3>
    <div class="qm-hint">Pick devices from the suggestions (or type a serial and press comma / Enter) to stack up multiple, then move them all at once.</div>
    <div class="row">
      <div class="qm-input-wrap">
        <div class="qm-tag-box" id="qm-tag-box">
          <div class="qm-tags" id="qm-tags"></div>
          <input type="text" id="qm-serial" placeholder="Type or scan a serial number...">
        </div>
        <div class="qm-suggestions" id="qm-suggestions"></div>
