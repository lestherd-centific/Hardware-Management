// --- Quick move by serial number (supports tagging multiple devices) ---
let qmTaggedIds = [];

function qmRefreshDest(){
  const sel = document.getElementById("qm-dest");
  const prev = sel.value;
  sel.innerHTML = state.buckets.map(b => `<option value="${b}">${b}</option>`).join("");
  if (state.buckets.includes(prev)) sel.value = prev;
}

function qmRenderTags(){
  const box = document.getElementById("qm-tags");
  box.innerHTML = qmTaggedIds.map(id => {
    const d = state.devices.find(x => x.id === id);
    if (!d) return "";
    return `<span class="qm-tag" data-id="${id}">${d.serial}<button type="button" data-id="${id}" title="Remove">✕</button></span>`;
  }).join("");
  box.querySelectorAll("button[data-id]").forEach(btn => {
    btn.addEventListener("click", () => qmRemoveTag(btn.getAttribute("data-id")));
  });
}

function qmAddTag(id){
  if (!qmTaggedIds.includes(id)) qmTaggedIds.push(id);
  qmRenderTags();
  const input = document.getElementById("qm-serial");
  input.value = "";
  document.getElementById("qm-suggestions").classList.remove("open");
  document.getElementById("qm-feedback").textContent = "";
  input.focus();
}

function qmRemoveTag(id){
  qmTaggedIds = qmTaggedIds.filter(x => x !== id);
  qmRenderTags();
}

function qmRenderSuggestions(query){
  const box = document.getElementById("qm-suggestions");
  if (!query){ box.classList.remove("open"); box.innerHTML = ""; return; }
  const q = query.trim().toLowerCase();
  const matches = state.devices.filter(d => !qmTaggedIds.includes(d.id) && d.serial.toLowerCase().includes(q)).slice(0, 8);
  if (matches.length === 0){
    box.innerHTML = `<div class="item">No devices match that serial number.</div>`;
    box.classList.add("open");
    return;
  }
  box.innerHTML = matches.map(d => `
    <div class="item" data-id="${d.id}">
      <b>${d.serial}</b> — ${d.model} (${d.tag})
      <div class="where">Currently: ${d.bucket} · ${statusLabel(d.status)}</div>
    </div>
  `).join("");
  box.classList.add("open");
  box.querySelectorAll(".item[data-id]").forEach(el => {
    el.addEventListener("click", () => qmAddTag(el.getAttribute("data-id")));
  });
}

document.getElementById("qm-serial").addEventListener("input", e => {
  document.getElementById("qm-feedback").textContent = "";
  const val = e.target.value;
  if (val.includes(",")){
    // Everything before the last comma gets attempted as tags; whatever's
    // after the last comma stays in the box for the user to keep typing.
    const parts = val.split(",");
    const tail = parts.pop();
    parts.forEach(part => {
      part = part.trim();
      if (!part) return;
      const match = state.devices.find(d => !qmTaggedIds.includes(d.id) && d.serial.toLowerCase() === part.toLowerCase());
      if (match) qmAddTag(match.id);
    });
    e.target.value = tail;
    qmRenderSuggestions(tail);
    return;
  }
  qmRenderSuggestions(val);
});

document.getElementById("qm-serial").addEventListener("keydown", e => {
  const input = e.target;
  if (e.key === "Enter"){
    e.preventDefault();
    const query = input.value.trim();
    if (!query) return;
    const match = state.devices.find(d => !qmTaggedIds.includes(d.id) && d.serial.toLowerCase() === query.toLowerCase());
    if (match){
      qmAddTag(match.id);
    } else {
      const feedback = document.getElementById("qm-feedback");
      feedback.textContent = `No exact match for "${query}" — pick one from the suggestions list.`;
      feedback.className = "qm-feedback err";
    }
  } else if (e.key === "Backspace" && input.value === "" && qmTaggedIds.length){
    qmRemoveTag(qmTaggedIds[qmTaggedIds.length - 1]);
  }
});

document.getElementById("qm-move-btn").addEventListener("click", () => {
  const feedback = document.getElementById("qm-feedback");
  const input = document.getElementById("qm-serial");

  // Give any leftover typed text (not yet turned into a tag) one last chance to match.
  const leftover = input.value.trim();
  if (leftover){
    const match = state.devices.find(d => !qmTaggedIds.includes(d.id) && d.serial.toLowerCase() === leftover.toLowerCase());
    if (match) qmTaggedIds.push(match.id);
  }

  if (qmTaggedIds.length === 0){
    feedback.textContent = "Add at least one device — pick from the suggestions, or type a full serial and press comma/Enter.";
    feedback.className = "qm-feedback err";
    return;
  }

  const dest = document.getElementById("qm-dest").value;
  const devices = qmTaggedIds.map(id => state.devices.find(x => x.id === id)).filter(Boolean);
  let movedCount = 0, alreadyCount = 0;
  devices.forEach(d => {
    if (d.bucket === dest) alreadyCount++; else movedCount++;
    dropInto(d.id, dest);
  });

  feedback.textContent = devices.length === 1
    ? (movedCount ? `Moved ${devices[0].tag} (S/N ${devices[0].serial}) to ${dest}.` : `${devices[0].tag} is already in ${dest}.`)
    : `Moved ${movedCount} device${movedCount === 1 ? "" : "s"} to ${dest}` + (alreadyCount ? ` (${alreadyCount} already there).` : ".");
  feedback.className = "qm-feedback ok";

  qmTaggedIds = [];
  qmRenderTags();
  input.value = "";
  document.getElementById("qm-suggestions").classList.remove("open");
});

const THEME_KEY = "hw-tracker-theme";
function applyTheme(theme){
  document.documentElement.setAttribute("data-theme", theme);
  const btn = document.getElementById("themeToggle");
  if (btn) btn.textContent = theme === "dark" ? "☀️ Light" : "🌙 Dark";
  localStorage.setItem(THEME_KEY, theme);
}
document.getElementById("themeToggle").addEventListener("click", () => {
  const current = document.documentElement.getAttribute("data-theme") === "dark" ? "dark" : "light";
  applyTheme(current === "dark" ? "light" : "dark");
});
applyTheme(localStorage.getItem(THEME_KEY) || "light");

render();
</script>
</body>
