function seed(){
  return {
    buckets: [MASTER, "Project Alpha", "Project Beta"],
    devices: SEED_DEVICES.map(d => ({ ...d, bucket: MASTER, notes: [], location: "" })),
    log: [],
    featured: MASTER,
    archived: [],
    minimized: [],
    archivedCollapsed: false,
    locations: { [MASTER]: [], "Project Alpha": [], "Project Beta": [] },
    accessories: [],
    accTab: {},
    modelTags: {}
  };
}

function normalizeState(){
  if (!state.featured || !state.buckets.includes(state.featured)) state.featured = MASTER;
  if (!state.archived) state.archived = [];
  if (!state.minimized) state.minimized = [];
  if (typeof state.archivedCollapsed !== "boolean") state.archivedCollapsed = false;
  if (!state.log) state.log = [];
  if (!state.locations) state.locations = {};
  state.buckets.forEach(b => {
    if (!state.locations[b]) state.locations[b] = [];
  });
  state.devices.forEach(d => {
    if (!d.notes) d.notes = [];
    if (typeof d.location !== "string") d.location = "";
  });
  if (!state.accessories) state.accessories = [];
  if (!state.accTab) state.accTab = {};
  // Locations are now shared between the Hardware and Accessories tabs of a
  // project. Migrate anything from the older, separate per-tab accessory
  // location list (if this browser still has one saved) into the shared list.
  if (state.accLocations){
    state.buckets.forEach(b => {
      const extra = state.accLocations[b] || [];
      extra.forEach(name => {
        if (!state.locations[b].includes(name)) state.locations[b].push(name);
      });
    });
    delete state.accLocations;
  }
  state.buckets.forEach(b => {
    if (!state.accTab[b]) state.accTab[b] = "hardware";
  });
  state.accessories.forEach(a => {
    if (typeof a.tag !== "string") a.tag = "";
    if (typeof a.serial !== "string") a.serial = "";
    if (typeof a.location !== "string") a.location = "";
    if (!a.status) a.status = "instock";
    if (typeof a.bucket !== "string" || !state.buckets.includes(a.bucket)) a.bucket = MASTER;
  });
  if (state.summaryTab !== "hardware" && state.summaryTab !== "accessories") state.summaryTab = "hardware";
  if (!state.modelTags) state.modelTags = {};
}

let state = JSON.parse(localStorage.getItem(STORE_KEY) || "null") || seed();
normalizeState();

function save(){
  if (state.log.length > 200) state.log.length = 200;
  localStorage.setItem(STORE_KEY, JSON.stringify(state));
}
function logActivity(entry){ state.log.unshift(entry); }

function statusLabel(s){ return s === "instock" ? "In stock" : s === "inuse" ? "In use" : "Broken"; }

function matchesQuery(d, q){
  if (!q) return true;
  const tags = (state.modelTags[d.model] || []).join(" ");
  return [d.tag, d.model, d.serial, tags].join(" ").toLowerCase().includes(q);
}

// Distinct model names already in use, for the Model-field autocomplete
// dropdowns on the Add Device / Add Accessory modals.
function existingHardwareModels(){
  return [...new Set(state.devices.map(d => d.model).filter(Boolean))]
    .sort((a, b) => a.localeCompare(b, undefined, { sensitivity: "base" }));
}
function existingAccessoryModels(){
  return [...new Set(state.accessories.map(a => a.model).filter(Boolean))]
    .sort((a, b) => a.localeCompare(b, undefined, { sensitivity: "base" }));
}

// Wires a text input to a suggestion dropdown that filters as you type,
// matching anywhere in the string (not just the start), and fills the input
// on click. Used for the Model fields so people reuse existing model names
// instead of accidentally creating near-duplicates (e.g. "Surface Laptop 6"
// vs "surface laptop6").
function setupModelAutocomplete(inputEl, dropdownEl, getModels){
  function showSuggestions(){
    const q = inputEl.value.trim().toLowerCase();
    const models = getModels();
    const filtered = (q ? models.filter(m => m.toLowerCase().includes(q)) : models).slice(0, 8);
    if (filtered.length === 0){ dropdownEl.classList.remove("open"); dropdownEl.innerHTML = ""; return; }
    dropdownEl.innerHTML = filtered.map(m => `<div class="item" data-model="${m}">${m}</div>`).join("");
    dropdownEl.classList.add("open");
  }
  inputEl.addEventListener("input", showSuggestions);
  inputEl.addEventListener("focus", showSuggestions);
  dropdownEl.addEventListener("click", (e) => {
    const item = e.target.closest(".item");
    if (!item) return;
    inputEl.value = item.getAttribute("data-model");
    dropdownEl.classList.remove("open");
  });
  document.addEventListener("click", (e) => {
    if (!inputEl.contains(e.target) && !dropdownEl.contains(e.target)) dropdownEl.classList.remove("open");
  });
}

function destOptions(currentBucket){
  return state.buckets.map(b => `<option value="${b}" ${b===currentBucket?"selected":""}>${b}</option>`).join("");
}

function locOptions(locs, current){
  return `<option value="" ${!current ? "selected" : ""}>Unassigned</option>` +
    locs.map(l => `<option value="${l}" ${current===l?"selected":""}>${l}</option>`).join("");
}

// --- Column sorting (click Serial / Tag / Model / Status headers) ---
let sortField = null; // 'serial' | 'tag' | 'model' | 'status'
let sortDir = "asc";

function setSort(field){
  if (sortField === field){ sortDir = sortDir === "asc" ? "desc" : "asc"; }
  else { sortField = field; sortDir = "asc"; }
  render();
}

function sortDevices(list){
  if (!sortField) return list;
  const copy = [...list];
  copy.sort((a, b) => {
    const av = sortField === "status" ? statusLabel(a.status) : (a[sortField] || "");
    const bv = sortField === "status" ? statusLabel(b.status) : (b[sortField] || "");
    const cmp = String(av).localeCompare(String(bv), undefined, { numeric: true, sensitivity: "base" });
    return sortDir === "asc" ? cmp : -cmp;
  });
  return copy;
}

function sortLabel(field, text){
  const active = sortField === field;
  const arrow = active ? (sortDir === "asc" ? " ▲" : " ▼") : "";
  return `<span class="sortable-col" data-field="${field}">${text}${arrow}</span>`;
}

function wireSortHeaders(container){
  container.querySelectorAll(".sortable-col[data-field]").forEach(el => {
    el.addEventListener("click", () => setSort(el.getAttribute("data-field")));
  });
}

