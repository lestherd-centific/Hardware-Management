const emptyHint = `<div class="empty-hint">No devices here</div>`;

// compact=true drops the Model column (used in the small sidebar panels).
// locs is the list of declared locations for this device's bucket — pass a
// non-empty array to add a Location column (used for projects, not Master).
function rowHTML(d, compact, locs){
  const hasLocs = !!(locs && locs.length);
  const sizeClass = (compact ? "compact" : "full") + (hasLocs ? " loc" : "");
  const modelCell = compact ? "" : `<span class="cell sub" title="${d.model}">${d.model}</span>`;
  const locCell = hasLocs ? `<select class="loc-select" data-id="${d.id}">${locOptions(locs, d.location)}</select>` : "";
  return `
    <div class="row ${sizeClass}" draggable="true" data-id="${d.id}">
      <span class="handle">⋮⋮</span>
      <span class="cell serial dd-open" data-id="${d.id}" title="View history &amp; notes for ${d.serial}">${d.serial}</span>
      <span class="cell tag" title="${d.tag}">${d.tag}${d.notes && d.notes.length ? `<span class="note-badge">📝${d.notes.length}</span>` : ""}</span>
      ${modelCell}
      <select class="status-select ${d.status}" data-id="${d.id}">
        <option value="instock" ${d.status==="instock"?"selected":""}>In stock</option>
        <option value="inuse" ${d.status==="inuse"?"selected":""}>In use</option>
        <option value="broken" ${d.status==="broken"?"selected":""}>Broken</option>
      </select>
      ${locCell}
    </div>
  `;
}

function wireRows(container){
  container.querySelectorAll(".row").forEach(row => {
    const id = row.getAttribute("data-id");
    row.addEventListener("dragstart", e => {
      e.stopPropagation(); // don't let this bubble up into a mini-card's card-reorder drag
      e.dataTransfer.setData("text/plain", id);
    });
  });
  container.querySelectorAll(".status-select").forEach(sel => {
    sel.addEventListener("change", e => updateStatus(e.target.getAttribute("data-id"), e.target.value));
  });
  container.querySelectorAll(".loc-select").forEach(sel => {
    sel.addEventListener("change", e => updateLocation(e.target.getAttribute("data-id"), e.target.value));
  });
  container.querySelectorAll(".dd-open").forEach(el => {
    el.addEventListener("click", e => {
      e.stopPropagation();
      openDeviceDetail(el.getAttribute("data-id"));
    });
  });
}

function wireDropZone(el, bucket, kind){
  const dtype = kind === "accessory" ? "application/x-accessory" : "text/plain";
  el.addEventListener("dragover", e => {
    if (!e.dataTransfer.types.includes(dtype)) return;
    e.preventDefault();
    el.classList.add("dragover");
  });
  el.addEventListener("dragleave", () => el.classList.remove("dragover"));
  el.addEventListener("drop", e => {
    if (!e.dataTransfer.types.includes(dtype)) return;
    e.preventDefault();
    el.classList.remove("dragover");
    const id = e.dataTransfer.getData(dtype);
    if (kind === "accessory") moveAccessory(id, bucket);
    else dropInto(id, bucket);
  });
}

// Keeps the green drop boxes hidden until a row is actually being dragged,
// then reveals the matching kind of drop box everywhere at once (hardware
// boxes for a device drag, accessory boxes for an accessory drag). Uses the
// capture phase so it still fires even though row dragstart calls stopPropagation().
document.addEventListener("dragstart", e => {
  const row = e.target.closest && e.target.closest(".row");
  if (!row) return;
  if (row.classList.contains("acc")) document.body.classList.add("dragging-accessory");
  else document.body.classList.add("dragging-device");
}, true);
document.addEventListener("dragend", () => {
  document.body.classList.remove("dragging-device", "dragging-accessory");
}, true);

