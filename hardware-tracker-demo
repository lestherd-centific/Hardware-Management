// inside whichever project (or Master) they're assigned to, behind their own
// Accessories tab. Draggable into the green accessory drop box to move
// between projects. Tag and Serial are optional since these often won't have one.
function accRowHTML(a, compact, locs){
  const modelCell = compact ? "" : `<span class="cell sub" title="${a.model}">${a.model}</span>`;
  return `
    <div class="row acc ${compact ? "compact" : "full"}" draggable="true" data-id="${a.id}">
      <span class="handle">⋮⋮</span>
