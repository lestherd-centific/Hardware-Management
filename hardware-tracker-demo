      <span class="cell tag" title="${a.tag || "No tag"}">${a.tag || "—"}</span>
      ${modelCell}
      <select class="status-select ${a.status}" data-id="${a.id}">
        <option value="instock" ${a.status==="instock"?"selected":""}>In stock</option>
        <option value="inuse" ${a.status==="inuse"?"selected":""}>In use</option>
        <option value="broken" ${a.status==="broken"?"selected":""}>Broken</option>
      </select>
      <select class="acc-loc-select" data-id="${a.id}">${locOptions(locs || [], a.location)}</select>
      <button class="acc-del-btn" data-id="${a.id}" title="Delete accessory">🗑</button>
    </div>
  `;
}

function wireAccRows(container){
  container.querySelectorAll(".row.acc").forEach(row => {
    const id = row.getAttribute("data-id");
    row.addEventListener("dragstart", e => {
      e.stopPropagation(); // don't let this bubble up into a mini-card's card-reorder drag
      e.dataTransfer.setData("application/x-accessory", id);
    });
  });
  container.querySelectorAll(".status-select").forEach(sel => {
    sel.addEventListener("change", e => updateAccessoryStatus(e.target.getAttribute("data-id"), e.target.value));
  });
  container.querySelectorAll(".acc-loc-select").forEach(sel => {
    sel.addEventListener("change", e => updateAccessoryLocation(e.target.getAttribute("data-id"), e.target.value));
  });
  container.querySelectorAll(".acc-del-btn").forEach(btn => {
    btn.addEventListener("click", () => openDeleteAccessoryConfirm(btn.getAttribute("data-id")));
  });
}

function updateAccessoryStatus(id, newStatus){
  const a = state.accessories.find(x => x.id === id);
  if (!a || a.status === newStatus) return;
  a.status = newStatus;
  save();
  render();
}

function updateAccessoryLocation(id, newLoc){
  const a = state.accessories.find(x => x.id === id);
  if (!a || a.location === newLoc) return;
  a.location = newLoc;
  save();
  render();
}

function moveAccessory(id, bucket){
  const a = state.accessories.find(x => x.id === id);
  if (!a || a.bucket === bucket) return;
  a.bucket = bucket;
  a.location = ""; // locations are specific to the previous project, so reset to Unassigned
  save();
  render();
}

let deleteAccessoryId = null;
function openDeleteAccessoryConfirm(id){
  const a = state.accessories.find(x => x.id === id);
  if (!a) return;
  deleteAccessoryId = id;
  document.getElementById("delete-accessory-message").innerHTML =
    `Delete <b>${a.model}</b>${a.tag ? ` (${a.tag})` : ""}? This can't be undone.`;
  document.getElementById("deleteAccessoryConfirmBackdrop").classList.add("open");
}

function renderAccessoryRows(containerEl, accessories, locs, compact, bucket){
  if (!locs.length){
    containerEl.innerHTML = accessories.length
      ? accessories.map(a => accRowHTML(a, compact, locs)).join("")
      : `<div class="empty-hint">No accessories here yet — click + Accessory to add one.</div>`;
    wireAccRows(containerEl);
    return;
  }

  const known = new Set(locs);
  const groups = locs.map(name => ({ name, list: accessories.filter(a => a.location === name), isUnassigned: false }));
  groups.push({ name: "Unassigned", list: accessories.filter(a => !known.has(a.location)), isUnassigned: true });

  containerEl.innerHTML = groups.map(g => `
    <div class="loc-group">
      <div class="loc-group-head">
        <span>${g.name} <span class="loc-count">(${g.list.length})</span></span>
        ${g.isUnassigned ? "" : `<button class="loc-del-btn" data-loc="${g.name}" title="Delete location">✕ Remove</button>`}
      </div>
      ${g.list.length ? g.list.map(a => accRowHTML(a, compact, locs)).join("") : `<div class="empty-hint small">No accessories here</div>`}
    </div>
  `).join("");
  wireAccRows(containerEl);
  containerEl.querySelectorAll(".loc-del-btn").forEach(btn => {
    btn.addEventListener("click", () => openDeleteLocationConfirm(bucket, btn.getAttribute("data-loc")));
  });
}

function render(){
  const q = document.getElementById("search").value.trim().toLowerCase();

  if (!state.buckets.includes(state.featured)) state.featured = MASTER;
  const mainBucket = state.featured;
  const mainIsMaster = mainBucket === MASTER;
  const sidebarBuckets = state.buckets.filter(b => b !== mainBucket);

  // Main (pinned / featured) panel — always the big one on the left
  const mainEl = document.getElementById("main-panel");
  const mainDevices = sortDevices(state.devices.filter(d => d.bucket === mainBucket && matchesQuery(d, q)));
  const mainAccessories = sortAccessories(state.accessories.filter(a => a.bucket === mainBucket && matchesQuery(a, q)));
  // Hardware location grouping stays project-only (Master never groups its hardware).
  // Locations themselves are shared per bucket across both tabs, so Master's
  // Accessories tab can still have its own locations without affecting Master's Hardware tab.
  const mainHasLocs = !mainIsMaster && (state.locations[mainBucket] || []).length > 0;
  const mainAccLocs = state.locations[mainBucket] || [];
  const mainTab = state.accTab[mainBucket] || "hardware";
  mainEl.innerHTML = `
    <div class="panel-head">
      <div>
        <div class="tag">${mainIsMaster ? "Master · Redmond, WA" : "Project · Pinned"}</div>
        <h2>${mainBucket}</h2>
      </div>
      <div class="head-actions">
        <button class="icon-btn settings-btn" data-bucket="${mainBucket}" title="Project settings">⚙</button>
        ${mainIsMaster ? "" : `<button class="pin-btn unpin" data-bucket="${MASTER}">↩ Return Master to main</button>`}
        <span class="count-pill">${mainTab === "accessories" ? mainAccessories.length : mainDevices.length}</span>
      </div>
    </div>
    <div class="panel-tabs">
      <button class="tab-btn ${mainTab==="hardware"?"active":""}" data-bucket="${mainBucket}" data-tab="hardware">🖥 Hardware <span class="tab-count">${mainDevices.length}</span></button>
      <button class="tab-btn ${mainTab==="accessories"?"active":""}" data-bucket="${mainBucket}" data-tab="accessories">🎒 Accessories <span class="tab-count">${mainAccessories.length}</span></button>
      ${mainTab === "accessories" ? `<button class="tab-add-btn" data-bucket="${mainBucket}">+ Accessory</button>` : ""}
    </div>
    ${mainTab === "hardware" ? `
      <div class="drop-target" data-bucket="${mainBucket}" data-kind="hardware">⬇ Drop hardware here to move into ${mainBucket}</div>
      <div class="col-labels full${mainHasLocs ? " loc" : ""}"><span></span>${sortLabel("serial","Serial")}${sortLabel("tag","Tag")}${sortLabel("model","Model")}${sortLabel("status","Status")}${mainHasLocs ? "<span>Location</span>" : ""}</div>
      <div class="rows-list" id="main-rows"></div>
    ` : `
      <div class="drop-target" data-bucket="${mainBucket}" data-kind="accessory">⬇ Drop an accessory here to move into ${mainBucket}</div>
      <div class="col-labels acc full"><span></span>${accSortLabel("serial","Serial")}${accSortLabel("tag","Tag")}${accSortLabel("model","Model")}${accSortLabel("status","Status")}<span>Location</span><span></span></div>
      <div class="rows-list" id="main-acc-rows"></div>
    `}
  `;
  if (mainTab === "hardware"){
    renderBucketRows(document.getElementById("main-rows"), mainBucket, mainDevices, false);
  } else {
    renderAccessoryRows(document.getElementById("main-acc-rows"), mainAccessories, mainAccLocs, false, mainBucket);
  }
  wirePinButtons(mainEl);
  wireHeadButtons(mainEl);
  wireSortHeaders(mainEl);
  wireAccSortHeaders(mainEl);
  wireTabButtons(mainEl);

  // Sidebar — archived projects header first, then everything not currently pinned to main
  const sidebarEl = document.getElementById("sidebar-panel");
  sidebarEl.innerHTML = archivedSectionHTML() + sidebarBuckets.map(b => {
    const isMaster = b === MASTER;
    const isMin = state.minimized.includes(b);
    const tab = state.accTab[b] || "hardware";
    const count = state.devices.filter(d => d.bucket === b && matchesQuery(d, q)).length;
    const accCount = state.accessories.filter(a => a.bucket === b && matchesQuery(a, q)).length;
    // Hardware location grouping stays project-only; locations are shared per bucket across tabs.
    const bHasLocs = !isMaster && (state.locations[b] || []).length > 0;
    return `
      <div class="mini-card${isMin ? " minimized" : ""}" data-bucket="${b}" draggable="true">
        <div class="panel-head">
          <div>
            <div class="tag"><span class="card-handle" title="Drag to reorder">⠿</span>${isMaster ? "Master · Redmond, WA" : "Project"}</div>
            <h2>${b}</h2>
          </div>
          <div class="head-actions">
            <button class="icon-btn minimize-btn" data-bucket="${b}" title="${isMin ? "Expand" : "Minimize"}">${isMin ? "▸" : "▾"}</button>
            <button class="icon-btn settings-btn" data-bucket="${b}" title="Project settings">⚙</button>
            <button class="pin-btn" data-bucket="${b}">📌 Pin to main</button>
            <span class="count-pill">${tab === "accessories" ? accCount : count}</span>
          </div>
        </div>
        <div class="panel-tabs">
          <button class="tab-btn ${tab==="hardware"?"active":""}" data-bucket="${b}" data-tab="hardware">🖥 <span class="tab-count">${count}</span></button>
          <button class="tab-btn ${tab==="accessories"?"active":""}" data-bucket="${b}" data-tab="accessories">🎒 <span class="tab-count">${accCount}</span></button>
          ${tab === "accessories" ? `<button class="tab-add-btn" data-bucket="${b}">+</button>` : ""}
        </div>
        ${tab === "hardware" ? `
          <div class="drop-target" data-bucket="${b}" data-kind="hardware">⬇ Drop hardware here</div>
          <div class="col-labels compact${bHasLocs ? " loc" : ""}"><span></span>${sortLabel("serial","Serial")}${sortLabel("tag","Tag")}${sortLabel("status","Status")}${bHasLocs ? "<span>Location</span>" : ""}</div>
          <div class="rows-list" data-bucket="${b}"></div>
        ` : `
          <div class="drop-target" data-bucket="${b}" data-kind="accessory">⬇ Drop an accessory here</div>
          <div class="col-labels acc compact"><span></span>${accSortLabel("serial","Serial")}${accSortLabel("tag","Tag")}${accSortLabel("status","Status")}<span>Loc</span><span></span></div>
          <div class="rows-list" data-bucket="${b}"></div>
        `}
      </div>
    `;
  }).join("");

  sidebarBuckets.forEach(b => {
    const container = sidebarEl.querySelector(`.rows-list[data-bucket="${CSS.escape(b)}"]`);
    if (!container) return;
    const tab = state.accTab[b] || "hardware";
    if (tab === "hardware"){
      const devices = sortDevices(state.devices.filter(d => d.bucket === b && matchesQuery(d, q)));
      renderBucketRows(container, b, devices, true);
    } else {
      const accessories = sortAccessories(state.accessories.filter(a => a.bucket === b && matchesQuery(a, q)));
      renderAccessoryRows(container, accessories, state.locations[b] || [], true, b);
    }
  });
  wirePinButtons(sidebarEl);
  wireHeadButtons(sidebarEl);
  wireCardDrag(sidebarEl);
  wireSortHeaders(sidebarEl);
  wireAccSortHeaders(sidebarEl);
  wireTabButtons(sidebarEl);
  sidebarEl.querySelectorAll(".restore-btn").forEach(btn => {
    btn.addEventListener("click", () => restoreProject(btn.getAttribute("data-name")));
  });
  sidebarEl.querySelectorAll(".settings-btn-archived").forEach(btn => {
    btn.addEventListener("click", () => openArchivedSettings(btn.getAttribute("data-name")));
  });
  const archivedToggle = document.getElementById("archivedToggle");
  if (archivedToggle) archivedToggle.addEventListener("click", () => {
    state.archivedCollapsed = !state.archivedCollapsed;
    save();
    render();
  });
  wireDropTarget(mainEl);
  wireDropTarget(sidebarEl);

  renderLog();
  qmRefreshDest();
  renderModelSummary();
}

function archivedSectionHTML(){
  if (state.archived.length === 0) return "";
  const collapsed = state.archivedCollapsed;
  return `
    <div class="archived-panel${collapsed ? " collapsed" : ""}">
      <div class="archived-panel-head" id="archivedToggle">
        <span>Archived Projects (${state.archived.length})</span>
        <span class="archived-toggle">${collapsed ? "▸" : "▾"}</span>
      </div>
      ${state.archived.map(a => `
        <div class="archived-item">
          <div><b>${a.name}</b><div class="meta">Archived ${a.archivedAt}</div></div>
          <div class="archived-item-actions">
            <button class="icon-btn settings-btn-archived" data-name="${a.name}" title="Project settings">⚙</button>
            <button class="restore-btn" data-name="${a.name}">↩ Restore</button>
          </div>
        </div>
      `).join("")}
    </div>
  `;
}

function renderModelSummary(){
  document.querySelectorAll("#summary-tabs .tab-btn").forEach(btn => {
    btn.classList.toggle("active", btn.getAttribute("data-summary-tab") === state.summaryTab);
  });
  document.getElementById("hw-model-table-wrap").style.display = state.summaryTab === "hardware" ? "" : "none";
  document.getElementById("acc-model-table-wrap").style.display = state.summaryTab === "accessories" ? "" : "none";

  renderHardwareModelTable();
  renderAccessoryModelTable();
}

function renderHardwareModelTable(){
  const body = document.getElementById("model-table-body");
  const foot = document.getElementById("model-table-foot");

  // Count devices currently sitting in Master Inventory, grouped by model.
  const counts = {};
  state.devices.filter(d => d.bucket === MASTER).forEach(d => {
    if (!counts[d.model]) counts[d.model] = { total: 0, instock: 0, inuse: 0, broken: 0 };
    counts[d.model].total++;
    counts[d.model][d.status]++;
  });

  const models = Object.keys(counts).sort((a,b) => counts[b].total - counts[a].total);

  if (models.length === 0){
    body.innerHTML = `<tr><td colspan="5" class="empty-hint">No devices currently in Master Inventory.</td></tr>`;
    foot.innerHTML = "";
    return;
  }

  body.innerHTML = models.map(m => {
    const c = counts[m];
    return `
      <tr class="model-row-click" data-model="${m}" data-kind="hardware" title="Click for a project breakdown and tags">
        <td>${m}</td>
        <td class="num">${c.total}</td>
        <td class="num status-num instock">${c.instock}</td>
        <td class="num status-num inuse">${c.inuse}</td>
        <td class="num status-num broken">${c.broken}</td>
      </tr>
    `;
  }).join("");
  body.querySelectorAll(".model-row-click").forEach(tr => {
    tr.addEventListener("click", () => openModelDetail(tr.getAttribute("data-kind"), tr.getAttribute("data-model")));
  });

  const totals = models.reduce((acc, m) => {
    const c = counts[m];
    acc.total += c.total; acc.instock += c.instock; acc.inuse += c.inuse; acc.broken += c.broken;
    return acc;
  }, { total:0, instock:0, inuse:0, broken:0 });

  foot.innerHTML = `
    <tr>
      <td>Total</td>
      <td class="num">${totals.total}</td>
      <td class="num status-num instock">${totals.instock}</td>
      <td class="num status-num inuse">${totals.inuse}</td>
      <td class="num status-num broken">${totals.broken}</td>
    </tr>
  `;
}

// Accessory availability, broken out by model + project + location (since,
// unlike hardware, accessories are spread across every project rather than
// just Master, location and project are the useful breakdown here).
function renderAccessoryModelTable(){
  const body = document.getElementById("acc-model-table-body");
  const foot = document.getElementById("acc-model-table-foot");

  const counts = {};
  state.accessories.forEach(a => {
    const key = `${a.model}␀${a.bucket}␀${a.location || "Unassigned"}`;
    if (!counts[key]) counts[key] = { model: a.model, bucket: a.bucket, location: a.location || "Unassigned", qty: 0 };
    counts[key].qty++;
  });

  const rows = Object.values(counts).sort((x, y) =>
    x.model.localeCompare(y.model, undefined, { sensitivity: "base" }) ||
    x.bucket.localeCompare(y.bucket, undefined, { sensitivity: "base" }) ||
    x.location.localeCompare(y.location, undefined, { sensitivity: "base" })
  );

  if (rows.length === 0){
    body.innerHTML = `<tr><td colspan="4" class="empty-hint">No accessories added yet.</td></tr>`;
    foot.innerHTML = "";
    return;
  }

  body.innerHTML = rows.map(r => `
    <tr class="model-row-click" data-model="${r.model}" data-kind="accessory" title="Click for a project breakdown and tags">
      <td>${r.model}</td>
      <td>${r.bucket}</td>
      <td>${r.location}</td>
      <td class="num">${r.qty}</td>
    </tr>
  `).join("");
  body.querySelectorAll(".model-row-click").forEach(tr => {
    tr.addEventListener("click", () => openModelDetail(tr.getAttribute("data-kind"), tr.getAttribute("data-model")));
  });

  const total = rows.reduce((sum, r) => sum + r.qty, 0);
  foot.innerHTML = `
    <tr>
      <td colspan="3">Total</td>
      <td class="num">${total}</td>
    </tr>
  `;
}

// --- Model detail modal: project/location breakdown + custom name tags ---
// Opened by clicking a model row in Availability by Model. Tags entered here
// are stored per-model and get picked up by the top search bar via matchesQuery().
let modelDetailTarget = null; // { kind: "hardware"|"accessory", model: "..." }
const modelDetailModal = document.getElementById("modelDetailBackdrop");

function openModelDetail(kind, model){
  modelDetailTarget = { kind, model };
  document.getElementById("md-title").textContent = model;
  document.getElementById("md-subtitle").textContent = kind === "hardware" ? "Hardware model" : "Accessory model";

  const items = kind === "hardware"
    ? state.devices.filter(d => d.model === model)
    : state.accessories.filter(a => a.model === model);

  // Simple per-project breakdown: how many of this model sit in each bucket
  // (Master Inventory included), rather than a row-by-row item table.
  const counts = {};
  items.forEach(it => { counts[it.bucket] = (counts[it.bucket] || 0) + 1; });
  const bucketNames = Object.keys(counts).sort((a, b) => {
    if (a === MASTER) return -1;
    if (b === MASTER) return 1;
    return a.localeCompare(b, undefined, { sensitivity: "base" });
  });

  const listEl = document.getElementById("md-breakdown-list");
  if (bucketNames.length === 0){
    listEl.innerHTML = `<div class="empty-hint small">No items of this model found.</div>`;
  } else {
    listEl.innerHTML = bucketNames.map(b => `
      <div class="md-breakdown-row">
        <span class="proj">${b}${b === MASTER ? `<span class="master-tag">(Master)</span>` : ""}</span>
        <span class="qty">${counts[b]}</span>
      </div>
    `).join("");
  }
  document.getElementById("md-count").textContent = `${items.length} total across all projects`;

  renderModelTagChips();
  document.getElementById("md-tag-input").value = "";
  modelDetailModal.classList.add("open");
}

function renderModelTagChips(){
  if (!modelDetailTarget) return;
  const tags = state.modelTags[modelDetailTarget.model] || [];
  const wrap = document.getElementById("md-tag-chips");
  if (tags.length === 0){
    wrap.innerHTML = `<div class="empty-hint small">No tags yet.</div>`;
    return;
  }
  wrap.innerHTML = tags.map(t => `
    <span class="model-tag">${t}<button class="md-tag-del" data-tag="${t}" title="Remove tag">✕</button></span>
  `).join("");
  wrap.querySelectorAll(".md-tag-del").forEach(btn => {
    btn.addEventListener("click", () => removeModelTag(modelDetailTarget.model, btn.getAttribute("data-tag")));
  });
}

function addModelTag(model, text){
  const tag = text.trim();
  if (!tag) return;
  const list = state.modelTags[model] || (state.modelTags[model] = []);
  if (list.some(t => t.toLowerCase() === tag.toLowerCase())) return;
  list.push(tag);
  save();
  renderModelTagChips();
  renderModelSummary();
}

function removeModelTag(model, tag){
  const list = state.modelTags[model];
  if (!list) return;
  state.modelTags[model] = list.filter(t => t !== tag);
  if (state.modelTags[model].length === 0) delete state.modelTags[model];
  save();
  renderModelTagChips();
  renderModelSummary();
}

document.getElementById("md-add-tag-btn").addEventListener("click", () => {
  if (!modelDetailTarget) return;
  addModelTag(modelDetailTarget.model, document.getElementById("md-tag-input").value);
  document.getElementById("md-tag-input").value = "";
  document.getElementById("md-tag-input").focus();
});
document.getElementById("md-tag-input").addEventListener("keydown", (e) => {
  if (e.key === "Enter"){
    e.preventDefault();
    document.getElementById("md-add-tag-btn").click();
  }
});
document.getElementById("md-close").addEventListener("click", () => modelDetailModal.classList.remove("open"));

// Moves a device to a different bucket. Used by drag-drop, the dest dropdown,
// and quick-move-by-serial.
function dropInto(id, bucket){
  const d = state.devices.find(x => x.id === id);
  if (!d || d.bucket === bucket) return;
  const from = d.bucket;
  d.bucket = bucket;
  d.location = ""; // location is specific to the previous project, so reset to Unassigned
  logActivity({ ts: new Date().toLocaleString(), type: "move", tag: d.serial, deviceId: d.id, from, to: bucket });
  save();
  render();
}

function updateStatus(id, newStatus){
  const d = state.devices.find(x => x.id === id);
  if (!d || d.status === newStatus) return;
  const from = d.status;
  d.status = newStatus;
  logActivity({ ts: new Date().toLocaleString(), type: "status", tag: d.serial, deviceId: d.id, from: statusLabel(from), to: statusLabel(newStatus) });
  save();
  render();
}

function updateLocation(id, newLoc){
  const d = state.devices.find(x => x.id === id);
  if (!d || d.location === newLoc) return;
  const from = d.location || "Unassigned";
  d.location = newLoc;
  logActivity({ ts: new Date().toLocaleString(), type: "location", tag: d.serial, deviceId: d.id, from, to: newLoc || "Unassigned" });
  save();
  render();
}

// --- Device detail: history + notes ---
let deviceDetailId = null;

function openDeviceDetail(id){
  deviceDetailId = id;
  const d = state.devices.find(x => x.id === id);
  if (!d) return;

  document.getElementById("dd-title").textContent = `${d.tag} — ${d.model}`;
  document.getElementById("dd-meta").innerHTML = `
    Serial: <b>${d.serial}</b><br>
    Status: <span class="dd-status-chip status-select ${d.status}">${statusLabel(d.status)}</span><br>
    Currently in: <b>${d.bucket}</b>
  `;

  const history = state.log.filter(e => e.deviceId === id);
  const histEl = document.getElementById("dd-history");
  histEl.innerHTML = history.length ? history.map(e => {
    let text;
    if (e.type === "status") text = `Status changed from ${e.from} to <b>${e.to}</b>`;
    else if (e.type === "location") text = `Location changed from ${e.from} to <b>${e.to}</b>`;
    else text = `Moved from ${e.from} to <b>${e.to}</b>`;
    return `<div class="log-entry">${text}<br>${e.ts}</div>`;
  }).join("") : `<div class="log-entry">No tracked history yet.</div>`;

  renderNotesList(d);
  document.getElementById("dd-note-input").value = "";
  document.getElementById("deviceDetailBackdrop").classList.add("open");
}

function renderNotesList(d){
  const notesEl = document.getElementById("dd-notes");
  if (!d.notes || d.notes.length === 0){
    notesEl.innerHTML = `<div class="log-entry">No notes yet.</div>`;
    return;
  }
  notesEl.innerHTML = d.notes.map((n, i) => `
    <div class="dd-note-item">
      <span class="txt">${n.text}</span>
      <span class="date">${n.ts}</span>
      <button class="dd-note-del" data-idx="${i}" title="Delete note">✕</button>
    </div>
  `).join("");
  notesEl.querySelectorAll(".dd-note-del").forEach(btn => {
    btn.addEventListener("click", () => {
      const idx = parseInt(btn.getAttribute("data-idx"), 10);
      d.notes.splice(idx, 1);
      save();
      renderNotesList(d);
      render();
    });
  });
}

// Opens the on-theme confirmation modal for archiving. If the project still has
// devices in it, it shows a blocking message instead of the archive action.
let archiveTargetBucket = null;
function openArchiveConfirm(bucket){
  const devCount = state.devices.filter(d => d.bucket === bucket).length;
  const accCount = state.accessories.filter(a => a.bucket === bucket).length;
  const count = devCount + accCount;
  archiveTargetBucket = bucket;
  const msgEl = document.getElementById("archive-confirm-message");
  const okBtn = document.getElementById("archive-confirm-ok");
  const cancelBtn = document.getElementById("archive-confirm-cancel");

  if (count > 0){
    const parts = [];
    if (devCount) parts.push(`${devCount} device${devCount===1?"":"s"}`);
    if (accCount) parts.push(`${accCount} accessor${accCount===1?"y":"ies"}`);
    msgEl.innerHTML = `Move everything out of <b>${bucket}</b> before it can be archived.<br><br>${parts.join(" and ")} still assigned there.`;
    okBtn.style.display = "none";
    cancelBtn.textContent = "OK";
  } else {
    msgEl.innerHTML = `Archive <b>${bucket}</b>? It will move to the Archived Projects list and can be restored anytime.`;
    okBtn.style.display = "";
    cancelBtn.textContent = "Cancel";
  }
  document.getElementById("archiveConfirmBackdrop").classList.add("open");
}

function doArchive(bucket){
  state.buckets = state.buckets.filter(b => b !== bucket);
  state.archived.push({ name: bucket, archivedAt: new Date().toLocaleString() });
  if (state.featured === bucket) state.featured = MASTER;
  logActivity({ ts: new Date().toLocaleString(), type: "archive", tag: bucket, from: "Active", to: "Archived" });
  save();
  render();
}

function restoreProject(name){
  const rec = state.archived.find(a => a.name === name);
  if (!rec) return;
  if (state.buckets.includes(name)){ alert("A project with that name already exists."); return; }
  state.buckets.push(name);
  if (!state.locations[name]) state.locations[name] = [];
  state.archived = state.archived.filter(a => a.name !== name);
  logActivity({ ts: new Date().toLocaleString(), type: "archive", tag: name, from: "Archived", to: "Active" });
  save();
  render();
}

function renderLog(){
  const el = document.getElementById("logList");
  if (state.log.length === 0){
    el.innerHTML = `<div class="log-entry">No activity yet.</div>`;
    return;
  }
  el.innerHTML = state.log.slice(0,60).map(e => {
    let text;
    if (e.type === "status") text = `<b>${e.tag}</b> status changed from ${e.from} to <b>${e.to}</b>`;
    else if (e.type === "location") text = `<b>${e.tag}</b> location changed from ${e.from} to <b>${e.to}</b>`;
    else if (e.type === "location-delete") text = `Location <b>${e.from}</b> deleted from <b>${e.tag}</b>` + (e.to > 0 ? ` (${e.to} device${e.to===1?"":"s"} moved to Unassigned)` : "");
    else if (e.type === "archive") text = e.to === "Archived" ? `<b>${e.tag}</b> project was archived` : `<b>${e.tag}</b> project was restored`;
    else if (e.type === "delete") text = `<b>${e.tag}</b> was deleted from ${e.from}`;
    else if (e.type === "rename") text = `Project <b>${e.from}</b> renamed to <b>${e.to}</b>`;
    else if (e.type === "delete-project") text = `Archived project <b>${e.tag}</b> was permanently deleted`;
    else text = `<b>${e.tag}</b> moved from ${e.from} → <b>${e.to}</b>`;
    return `<div class="log-entry">${text}<br>${e.ts}</div>`;
  }).join("");
}

