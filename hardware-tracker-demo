// Lets sidebar mini-cards be dragged to reorder the sidebar. Uses a distinct
// dataTransfer type so it never collides with dragging a device row.
function wireCardDrag(container){
  container.querySelectorAll(".mini-card").forEach(card => {
    const bucket = card.getAttribute("data-bucket");
    card.addEventListener("dragstart", e => {
      e.dataTransfer.setData("application/x-bucket-order", bucket);
      e.dataTransfer.effectAllowed = "move";
    });
    card.addEventListener("dragover", e => {
      if (!e.dataTransfer.types.includes("application/x-bucket-order")) return;
      e.preventDefault();
      card.classList.add("card-dragover");
    });
    card.addEventListener("dragleave", () => card.classList.remove("card-dragover"));
    card.addEventListener("drop", e => {
      if (!e.dataTransfer.types.includes("application/x-bucket-order")) return;
      e.preventDefault();
      card.classList.remove("card-dragover");
      const draggedBucket = e.dataTransfer.getData("application/x-bucket-order");
      reorderBucket(draggedBucket, bucket);
    });
  });
}

function reorderBucket(draggedBucket, targetBucket){
  if (draggedBucket === targetBucket) return;
  const fromIdx = state.buckets.indexOf(draggedBucket);
  if (fromIdx === -1) return;
  state.buckets.splice(fromIdx, 1);
  const toIdx = state.buckets.indexOf(targetBucket);
  if (toIdx === -1){ state.buckets.push(draggedBucket); } else { state.buckets.splice(toIdx, 0, draggedBucket); }
  save();
  render();
}

// Renders a bucket's devices as a flat row list.
function renderBucketRows(containerEl, bucket, devices, compact){
  const locs = state.locations[bucket] || [];

  if (locs.length === 0){
    containerEl.innerHTML = devices.length ? devices.map(d => rowHTML(d, compact, [])).join("") : emptyHint;
    wireRows(containerEl);
    return;
  }

  // Group devices under their declared location, plus a catch-all
  // "Unassigned" group for anything with no (or a since-deleted) location.
  const known = new Set(locs);
  const groups = locs.map(name => ({ name, devices: devices.filter(d => d.location === name), isUnassigned: false }));
  groups.push({ name: "Unassigned", devices: devices.filter(d => !known.has(d.location)), isUnassigned: true });

  containerEl.innerHTML = groups.map(g => `
    <div class="loc-group">
      <div class="loc-group-head">
        <span>${g.name} <span class="loc-count">(${g.devices.length})</span></span>
        ${g.isUnassigned ? "" : `<button class="loc-del-btn" data-bucket="${bucket}" data-loc="${g.name}" title="Delete location">✕ Remove</button>`}
      </div>
      ${g.devices.length ? g.devices.map(d => rowHTML(d, compact, locs)).join("") : `<div class="empty-hint small">No devices here</div>`}
    </div>
  `).join("");
  wireRows(containerEl);
  containerEl.querySelectorAll(".loc-del-btn").forEach(btn => {
    btn.addEventListener("click", () => openDeleteLocationConfirm(btn.getAttribute("data-bucket"), btn.getAttribute("data-loc")));
  });
}

// Wires the dedicated dashed drop-target box(es) inside a container to accept
// device drops for the bucket named in their data-bucket attribute. Dropping
// hardware is intentionally limited to this box (rather than anywhere in the
// row list) to cut down on accidental moves.
function wireDropTarget(container){
  container.querySelectorAll(".drop-target").forEach(el => {
    const kind = el.getAttribute("data-kind") || "hardware";
    wireDropZone(el, el.getAttribute("data-bucket"), kind);
  });
}

